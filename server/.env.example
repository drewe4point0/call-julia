PORT=3789
CORS_ORIGINS=*

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# LLM settings
# Use "openai-compatible" for Claude Max proxy / OpenAI-compatible endpoints
# Use "anthropic" for direct Anthropic calls
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://localhost:3456
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=450

# Anthropic (required only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01

# Telegram action + summary delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ACTION_TELEGRAM_PREFIX=Drewe and I just talked about this so let's make sure that it happens:
MAX_ACTIONS_PER_RESPONSE=1
ACTION_DEDUP_WINDOW_SEC=180

# Optional iMessage action delivery
ENABLE_IMESSAGE=false
IMESSAGE_TO=

# Context / memory
ASSISTANT_NAME=Julia
TIMEZONE=America/Vancouver
BRAIN_DIR=../brain
MEMORY_DIR=../brain/memory
CONTEXT_FILES=soul.md,claude.md,user.md,memories.md,memory.md,tools.md
RECENT_MEMORY_FILES=2
CONTEXT_CACHE_TTL_MS=60000

# Optional remote context source (recommended for Vercel)
# Example:
# BRAIN_REMOTE_BASE_URL=https://raw.githubusercontent.com/<owner>/<repo>/<branch>/path/to/brain
BRAIN_REMOTE_BASE_URL=
BRAIN_REMOTE_MEMORY_PATH=memory
BRAIN_REMOTE_TIMEOUT_MS=6000
BRAIN_REMOTE_AUTH_TOKEN=

# Preferred GitHub API mode (supports private repos)
GITHUB_BRAIN_OWNER=
GITHUB_BRAIN_REPO=
GITHUB_BRAIN_BRANCH=main
GITHUB_BRAIN_ROOT_PATH=
GITHUB_BRAIN_TOKEN=
